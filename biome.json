{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "!**/dist",
      "!**/node_modules",
      "!**/coverage",
      "!frontend/src/routeTree.gen.ts",
      "!backend/src/generated"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn",
        "noAssignInExpressions": "warn",
        "noDoubleEquals": "warn"
      },
      "correctness": {
        "noChildrenProp": "off"
      },
      "a11y": {
        "useAriaPropsSupportedByRole": "warn",
        "useSemanticElements": "warn"
      },
      "complexity": {
        "noBannedTypes": "off"
      }
    }
  },
  "javascript": {
    "globals": ["NodeJS"],
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  }
}
